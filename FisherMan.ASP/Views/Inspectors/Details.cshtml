@model FisherMan.ASP.Models.Domain.Inspector

@{
    ViewData["Title"] = "Детайли за инспектор";
}

<h2>@ViewData["Title"]</h2>

<div class="card col-md-5 mb-3">
    <div class="card-header bg-primary text-white">@Model.Name</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Номер значка</dt>
            <dd class="col-sm-7">@Model.BadgeNumber</dd>
            <dt class="col-sm-5">Телефон</dt>
            <dd class="col-sm-7">@Model.Phone</dd>
        </dl>
    </div>
</div>

<h4>Инспекции (@Model.Inspections.Count)</h4>
<table class="table table-sm table-bordered">
    <thead class="table-light">
        <tr>
            <th>Дата</th>
            <th>Тип</th>
            <th>Обект</th>
            <th>Нарушение</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var insp in Model.Inspections.OrderByDescending(i => i.InspectionDate))
        {
            <tr>
                <td>@insp.InspectionDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@insp.Type.GetDisplayName()</td>
                <td>@insp.InspectedObject</td>
                <td>
                    @if (insp.HasViolation)
                    {
                        <span class="badge bg-danger">Да - @insp.FineAmount?.ToString("F2") лв.</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Не</span>
                    }
                </td>
            </tr>
        }
        @if (!Model.Inspections.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">Няма инспекции.</td></tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редакция</a>
    <a asp-action="Index" class="btn btn-secondary">Обратно</a>
</div>
