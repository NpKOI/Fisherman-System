@model IEnumerable<FisherMan.ASP.Models.Domain.Inspector>

@{
    ViewData["Title"] = "Инспектори";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-success">+ Добавяне</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Търсене по имена или номер на значка..." />
        <button type="submit" class="btn btn-primary">Търси</button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        }
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Три имена</th>
            <th>Номер значка</th>
            <th>Телефон</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.BadgeNumber</td>
                <td>@item.Phone</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="4" class="text-center text-muted">Няма намерени инспектори.</td></tr>
        }
    </tbody>
</table>
