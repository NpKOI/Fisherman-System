@model IEnumerable<FisherMan.ASP.Controllers.Report1Item>

@{
    ViewData["Title"] = "Справка 1: Кораби с изтичащо разрешително";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">Кораби с разрешително, което изтича в следващите 30 дни.</p>

@if (!Model.Any())
{
    <div class="alert alert-success">Няма кораби с изтичащо разрешително в следващия месец.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Маркировка</th>
                    <th>Собственик</th>
                    <th>Капитан</th>
                    <th>Дата на изтичане</th>
                    <th>Остават дни</th>
                    <th>Уреди</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var rowClass = item.DaysUntilExpiry <= 7 ? "table-danger" : "table-warning";
                    <tr class="@rowClass">
                        <td><strong>@item.Ship.Marking</strong></td>
                        <td>@item.Ship.OwnerName</td>
                        <td>@item.Permit.CaptainName</td>
                        <td>@item.Permit.ExpiryDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(item.DaysUntilExpiry <= 7 ? "bg-danger" : "bg-warning text-dark")">
                                @item.DaysUntilExpiry дни
                            </span>
                        </td>
                        <td>@item.Permit.FishingTools</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Обратно към справките</a>
</div>
