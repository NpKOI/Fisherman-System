@model IEnumerable<FisherMan.ASP.Controllers.Report2Item>

@{
    ViewData["Title"] = "Справка 2: Класация на любителите рибари";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">Класация на рибарите любители с най-голям улов за последната една година (в кг).</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Няма данни за любителски улов за последната година.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Три имена</th>
                    <th>ЕГН</th>
                    <th>Общ улов (кг)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Rank == 1 ? "table-warning" : item.Rank == 2 ? "table-light" : "")">
                        <td>
                            @if (item.Rank == 1) { <span>🥇</span> }
                            else if (item.Rank == 2) { <span>🥈</span> }
                            else if (item.Rank == 3) { <span>🥉</span> }
                            else { @item.Rank }
                        </td>
                        <td><strong>@item.HolderName</strong></td>
                        <td>@item.HolderEGN</td>
                        <td>@item.TotalCatchKg.ToString("F2") кг</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Обратно към справките</a>
</div>
