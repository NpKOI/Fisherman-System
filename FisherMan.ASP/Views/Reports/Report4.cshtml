@model IEnumerable<FisherMan.ASP.Controllers.Report4Item>

@{
    ViewData["Title"] = "Справка 4: Въглероден отпечатък";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">Въглероден отпечатък от улова на 1 кг риба за всеки кораб с активно разрешително (текуща година).<br/>
Изчислява се като: <em>общо гориво (л) / общо улов (кг)</em>.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Няма данни за активни кораби с риболовни излети за тази година.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Кораб</th>
                    <th>Собственик</th>
                    <th>Тип двигател</th>
                    <th>Общо гориво (л)</th>
                    <th>Общо улов (кг)</th>
                    <th>Отпечатък (л/кг)</th>
                </tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@rank</td>
                        <td><strong>@item.Ship.Marking</strong></td>
                        <td>@item.Ship.OwnerName</td>
                        <td>@item.Ship.EngineType</td>
                        <td>@item.TotalFuelL.ToString("F1")</td>
                        <td>@item.TotalCatchKg.ToString("F1")</td>
                        <td>
                            <span class="badge @(item.CarbonFootprint <= 1 ? "bg-success" : item.CarbonFootprint <= 3 ? "bg-warning text-dark" : "bg-danger")">
                                @item.CarbonFootprint.ToString("F3") л/кг
                            </span>
                        </td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
    <small class="text-muted">
        * По-малката стойност означава по-добра ефективност.<br/>
        * Изключени са кораби с изтекло разрешително.
    </small>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Обратно към справките</a>
</div>
