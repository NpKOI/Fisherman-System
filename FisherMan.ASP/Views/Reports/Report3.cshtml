@model IEnumerable<FisherMan.ASP.Controllers.Report3Item>

@{
    ViewData["Title"] = "Справка 3: Класация на риболовните кораби";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">Статистика за риболовната дейност на корабите за текущата година.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Няма данни за риболовни излети за тази година.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Кораб</th>
                    <th>Брой излети</th>
                    <th colspan="3" class="text-center">Продължителност (часове)</th>
                    <th colspan="3" class="text-center">Улов на излет (кг)</th>
                    <th>Общо улов (кг)</th>
                </tr>
                <tr class="table-secondary">
                    <th></th>
                    <th></th>
                    <th>Средна</th>
                    <th>Мин.</th>
                    <th>Макс.</th>
                    <th>Средно</th>
                    <th>Мин.</th>
                    <th>Макс.</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Ship.Marking</strong><br/><small class="text-muted">@item.Ship.OwnerName</small></td>
                        <td>@item.TripCount</td>
                        <td>@item.AvgDurationHours.ToString("F1")</td>
                        <td>@item.MinDurationHours.ToString("F1")</td>
                        <td>@item.MaxDurationHours.ToString("F1")</td>
                        <td>@item.AvgCatchKg.ToString("F1")</td>
                        <td>@item.MinCatchKg.ToString("F1")</td>
                        <td>@item.MaxCatchKg.ToString("F1")</td>
                        <td><strong>@item.TotalCatchKgYear.ToString("F1")</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Обратно към справките</a>
</div>
