@model IEnumerable<FisherMan.ASP.Models.Domain.FishingTrip>

@{
    ViewData["Title"] = "Дневник на риболовните операции";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-success">+ Добавяне</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Търсене по локация или маркировка..." />
        <button type="submit" class="btn btn-primary">Търси</button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Кораб</th>
                <th>Начало</th>
                <th>Край</th>
                <th>Продължителност (ч)</th>
                <th>Локация</th>
                <th>Уреди</th>
                <th>Улов (кг)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Permit?.Ship?.Marking</strong></td>
                    <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(item.EndDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                    <td>@(item.DurationHours.HasValue ? item.DurationHours.Value.ToString("F1") : "-")</td>
                    <td>@item.StartLocation</td>
                    <td>@item.FishingTools</td>
                    <td>@item.TotalCatchKg.ToString("F1")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детайли</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted">Няма намерени излети.</td></tr>
            }
        </tbody>
    </table>
</div>
