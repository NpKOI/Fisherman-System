@model FisherMan.ASP.Models.Domain.Inspection

@{
    ViewData["Title"] = "Детайли за инспекция";
}

<h2>@ViewData["Title"]</h2>

<div class="card col-md-6 mb-3">
    <div class="card-header bg-primary text-white">Инспекция от @Model.InspectionDate.ToString("dd.MM.yyyy")</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Инспектор</dt>
            <dd class="col-sm-8">@Model.Inspector?.Name (@Model.Inspector?.BadgeNumber)</dd>
            <dt class="col-sm-4">Дата</dt>
            <dd class="col-sm-8">@Model.InspectionDate.ToString("dd.MM.yyyy HH:mm")</dd>
            <dt class="col-sm-4">Тип</dt>
            <dd class="col-sm-8">@Model.Type.GetDisplayName()</dd>
            <dt class="col-sm-4">Проверен обект</dt>
            <dd class="col-sm-8">@Model.InspectedObject</dd>
            <dt class="col-sm-4">Бележки</dt>
            <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Notes) ? "-" : Model.Notes)</dd>
            <dt class="col-sm-4">Нарушение</dt>
            <dd class="col-sm-8">
                @if (Model.HasViolation)
                {
                    <span class="badge bg-danger">Да</span>
                }
                else
                {
                    <span class="badge bg-success">Не</span>
                }
            </dd>
            @if (Model.HasViolation)
            {
                <dt class="col-sm-4">Номер акт</dt>
                <dd class="col-sm-8">@Model.ActNumber</dd>
                <dt class="col-sm-4">Глоба</dt>
                <dd class="col-sm-8"><strong>@Model.FineAmount?.ToString("F2") лв.</strong></dd>
            }
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редакция</a>
    <a asp-action="Index" class="btn btn-secondary">Обратно</a>
</div>
