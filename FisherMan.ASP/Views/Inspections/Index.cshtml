@model IEnumerable<FisherMan.ASP.Models.Domain.Inspection>

@{
    ViewData["Title"] = "Инспекции";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-success">+ Добавяне</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Търсене по обект или инспектор..." />
        <button type="submit" class="btn btn-primary">Търси</button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Дата</th>
                <th>Инспектор</th>
                <th>Тип</th>
                <th>Проверен обект</th>
                <th>Нарушение</th>
                <th>Глоба (лв)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.InspectionDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.Inspector?.Name</td>
                    <td>@item.Type.GetDisplayName()</td>
                    <td>@item.InspectedObject</td>
                    <td>
                        @if (item.HasViolation)
                        {
                            <span class="badge bg-danger">Да</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Не</span>
                        }
                    </td>
                    <td>@(item.FineAmount.HasValue ? item.FineAmount.Value.ToString("F2") : "-")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детайли</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted">Няма намерени инспекции.</td></tr>
            }
        </tbody>
    </table>
</div>
