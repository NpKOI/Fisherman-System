@model IEnumerable<FisherMan.ASP.Models.Domain.FishingTicket>

@{
    ViewData["Title"] = "Билети за любителски риболов";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-success">+ Добавяне</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Търсене по имена или ЕГН..." />
        <button type="submit" class="btn btn-primary">Търси</button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Три имена</th>
                <th>ЕГН</th>
                <th>Тип билет</th>
                <th>Издаден</th>
                <th>Изтича</th>
                <th>Цена (лв)</th>
                <th>Категория</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.HolderName</td>
                    <td>@item.HolderEGN</td>
                    <td>@item.ValidityType.GetDisplayName()</td>
                    <td>@item.IssueDate.ToString("dd.MM.yyyy")</td>
                    <td>@item.ExpiryDate.ToString("dd.MM.yyyy")</td>
                    <td>@item.Price.ToString("F2")</td>
                    <td>
                        @if (item.IsDisabled) { <span class="badge bg-info">Инвалид</span> }
                        else if (item.IsPensioner) { <span class="badge bg-secondary">Пенсионер</span> }
                        else if (item.IsUnder14) { <span class="badge bg-warning text-dark">До 14г.</span> }
                        else { <span class="badge bg-light text-dark">Стандарт</span> }
                    </td>
                    <td>
                        @if (item.IsValid)
                        {
                            <span class="badge bg-success">Валиден</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Изтекъл</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детайли</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="9" class="text-center text-muted">Няма намерени билети.</td></tr>
            }
        </tbody>
    </table>
</div>
