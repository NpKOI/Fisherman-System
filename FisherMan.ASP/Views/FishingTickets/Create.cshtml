@model FisherMan.ASP.Models.Domain.FishingTicket
@using FisherMan.ASP.Models.Domain

@{
    ViewData["Title"] = "Добавяне на билет";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="HolderName" class="form-label"></label>
                <input asp-for="HolderName" class="form-control" />
                <span asp-validation-for="HolderName" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="HolderEGN" class="form-label"></label>
                    <input asp-for="HolderEGN" class="form-control" maxlength="10" />
                    <span asp-validation-for="HolderEGN" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BirthDate" class="form-label"></label>
                    <input asp-for="BirthDate" class="form-control" type="date" />
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsDisabled" class="form-check-input" />
                <label asp-for="IsDisabled" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="DisabilityDecisionNumber" class="form-label"></label>
                <input asp-for="DisabilityDecisionNumber" class="form-control" placeholder="Номер на решение ТЕЛК" />
                <span asp-validation-for="DisabilityDecisionNumber" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsPensioner" class="form-check-input" />
                <label asp-for="IsPensioner" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="ValidityType" class="form-label"></label>
                <select asp-for="ValidityType" class="form-select"
                    asp-items="Html.GetEnumSelectList<TicketValidityType>()"></select>
                <span asp-validation-for="ValidityType" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="IssueDate" class="form-label"></label>
                    <input asp-for="IssueDate" class="form-control" type="date" />
                    <span asp-validation-for="IssueDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ExpiryDate" class="form-label"></label>
                    <input asp-for="ExpiryDate" class="form-control" type="date" />
                    <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mt-3">
                <input type="submit" value="Добавяне" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
