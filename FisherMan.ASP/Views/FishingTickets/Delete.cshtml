@model FisherMan.ASP.Models.Domain.FishingTicket

@{
    ViewData["Title"] = "Изтриване на билет";
}

<h2 class="text-danger">@ViewData["Title"]</h2>
<p>Сигурни ли сте, че искате да изтриете следния билет?</p>

<div class="card col-md-6 mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Три имена</dt>
            <dd class="col-sm-8">@Model.HolderName</dd>
            <dt class="col-sm-4">ЕГН</dt>
            <dd class="col-sm-8">@Model.HolderEGN</dd>
            <dt class="col-sm-4">Тип</dt>
            <dd class="col-sm-8">@Model.ValidityType.GetDisplayName()</dd>
            <dt class="col-sm-4">Изтича</dt>
            <dd class="col-sm-8">@Model.ExpiryDate.ToString("dd.MM.yyyy")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Изтриване" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</form>
