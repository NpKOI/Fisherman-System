@model FisherMan.ASP.Models.Domain.Ship

@{
    ViewData["Title"] = "Детайли за кораб";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">Идентификационни данни</div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5">Маркировка</dt>
                    <dd class="col-sm-7"><strong>@Model.Marking</strong></dd>
                    <dt class="col-sm-5">Международен №</dt>
                    <dd class="col-sm-7">@Model.InternationalNumber</dd>
                    <dt class="col-sm-5">Позивна</dt>
                    <dd class="col-sm-7">@Model.CallSign</dd>
                    <dt class="col-sm-5">Собственик</dt>
                    <dd class="col-sm-7">@Model.OwnerName</dd>
                    <dt class="col-sm-5">ЕГН собственик</dt>
                    <dd class="col-sm-7">@Model.OwnerEGN</dd>
                    <dt class="col-sm-5">Капитан</dt>
                    <dd class="col-sm-7">@Model.CaptainName</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">Технически параметри</div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5">Дължина (м)</dt>
                    <dd class="col-sm-7">@Model.Length.ToString("F2")</dd>
                    <dt class="col-sm-5">Ширина (м)</dt>
                    <dd class="col-sm-7">@Model.Width.ToString("F2")</dd>
                    <dt class="col-sm-5">Тонаж (т)</dt>
                    <dd class="col-sm-7">@Model.Tonnage.ToString("F2")</dd>
                    <dt class="col-sm-5">Газене (м)</dt>
                    <dd class="col-sm-7">@Model.Draft.ToString("F2")</dd>
                    <dt class="col-sm-5">Мощност двигател (кW)</dt>
                    <dd class="col-sm-7">@Model.EnginePower.ToString("F1")</dd>
                    <dt class="col-sm-5">Тип двигател</dt>
                    <dd class="col-sm-7">@Model.EngineType</dd>
                    <dt class="col-sm-5">Тип гориво</dt>
                    <dd class="col-sm-7">@Model.FuelType</dd>
                    <dt class="col-sm-5">Разход гориво (л/ч)</dt>
                    <dd class="col-sm-7">@Model.FuelConsumptionPerHour.ToString("F1")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<h4>Разрешителни (@Model.Permits.Count)</h4>
<table class="table table-sm table-bordered">
    <thead class="table-light">
        <tr>
            <th>Издадено</th>
            <th>Изтича</th>
            <th>Капитан</th>
            <th>Уреди</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var permit in Model.Permits.OrderByDescending(p => p.IssueDate))
        {
            <tr>
                <td>@permit.IssueDate.ToString("dd.MM.yyyy")</td>
                <td>@permit.ExpiryDate.ToString("dd.MM.yyyy")</td>
                <td>@permit.CaptainName</td>
                <td>@permit.FishingTools</td>
                <td>
                    @if (permit.IsRevoked)
                    {
                        <span class="badge bg-danger">Отнето</span>
                    }
                    else if (permit.ExpiryDate < DateTime.Today)
                    {
                        <span class="badge bg-warning text-dark">Изтекло</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Активно</span>
                    }
                </td>
            </tr>
        }
        @if (!Model.Permits.Any())
        {
            <tr><td colspan="5" class="text-center text-muted">Няма разрешителни.</td></tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редакция</a>
    <a asp-action="Index" class="btn btn-secondary">Обратно към списъка</a>
</div>
