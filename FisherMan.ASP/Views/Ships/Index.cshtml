@model IEnumerable<FisherMan.ASP.Models.Domain.Ship>

@{
    ViewData["Title"] = "Риболовни кораби";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Добавяне</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Търсене по маркировка, собственик, капитан..." />
        <button type="submit" class="btn btn-primary">Търси</button>
        @if (!string.IsNullOrEmpty(ViewData["Search"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Маркировка</th>
                <th>Международен №</th>
                <th>Позивна</th>
                <th>Собственик</th>
                <th>Капитан</th>
                <th>Дължина (м)</th>
                <th>Тонаж (т)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Marking</strong></td>
                    <td>@item.InternationalNumber</td>
                    <td>@item.CallSign</td>
                    <td>@item.OwnerName</td>
                    <td>@item.CaptainName</td>
                    <td>@item.Length.ToString("F1")</td>
                    <td>@item.Tonnage.ToString("F1")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детайли</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Изтриване</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">Няма намерени кораби.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
