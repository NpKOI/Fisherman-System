@model FisherMan.ASP.Models.Domain.Ship

@{
    ViewData["Title"] = "Изтриване на кораб";
}

<h2 class="text-danger">@ViewData["Title"]</h2>
<p>Сигурни ли сте, че искате да изтриете следния кораб?</p>

<div class="card col-md-6 mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Маркировка</dt>
            <dd class="col-sm-7"><strong>@Model.Marking</strong></dd>
            <dt class="col-sm-5">Международен №</dt>
            <dd class="col-sm-7">@Model.InternationalNumber</dd>
            <dt class="col-sm-5">Собственик</dt>
            <dd class="col-sm-7">@Model.OwnerName</dd>
            <dt class="col-sm-5">Капитан</dt>
            <dd class="col-sm-7">@Model.CaptainName</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Изтриване" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</form>
